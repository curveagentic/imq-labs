{
  "buildCommand": "npm --workspace apps/web run build",
  "outputDirectory": "apps/web/.next",
  "installCommand": "npm install --workspaces --include-workspace-root",
  "framework": "nextjs",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index?path=api/$1"
    },
    {
      "source": "/storage/(.*)",
      "destination": "/api/index?path=storage/$1"
    },
    {
      "source": "/health",
      "destination": "/api/index?path=health"
    }
  ]
}
