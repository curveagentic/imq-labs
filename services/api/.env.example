# --- Local dev defaults -------------------------------------------------------
PORT=4000
NODE_ENV=development

# Postgres
# Local docker compose:
DATABASE_URL=postgres://afrostream:afrostream@localhost:5432/afrostream
# Production (Supabase): use the Connection Pooler "Transaction" URI on port
# 6543, NOT the direct connection on 5432 — serverless functions can't hold
# pooled sockets and will exhaust direct connections.
# Example:
#   DATABASE_URL=postgres://postgres.<ref>:<pw>@aws-0-<region>.pooler.supabase.com:6543/postgres?sslmode=require

# Auth
JWT_SECRET=change_me_in_production_please
JWT_EXPIRES_IN=7d

# --- Storage ------------------------------------------------------------------
# Driver is auto-detected: if SUPABASE_URL is set it uses supabase, else local.
# Force explicitly with STORAGE_DRIVER=supabase | local.
STORAGE_DRIVER=local

# Local-disk driver (dev only):
STORAGE_LOCAL_DIR=../../infra/storage/data
STORAGE_PUBLIC_BASE_URL=http://localhost:4000/storage

# Supabase Storage driver (production):
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=imq-labs

# --- Third-party AI -----------------------------------------------------------
FAL_KEY=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- CORS ---------------------------------------------------------------------
# Comma-separated list of allowed origins. On Netlify the API runs same-origin
# so this only matters for non-prod environments.
WEB_ORIGIN=http://localhost:3000,http://localhost:3030
